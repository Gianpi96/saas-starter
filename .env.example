# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection details
POSTGRES_DB=saas_db
POSTGRES_USER=saas_user
# SECURITY: Use a strong random password in production
POSTGRES_PASSWORD=change_me_in_production

# Full async DSN used by the FastAPI backend
DATABASE_URL=postgresql+asyncpg://saas_user:change_me_in_production@localhost:5432/saas_db

# =============================================================================
# REDIS
# =============================================================================
# SECURITY: Use a strong random password in production
REDIS_PASSWORD=change_me_in_production
REDIS_URL=redis://:change_me_in_production@localhost:6379/0

# =============================================================================
# JWT / AUTH (Backend)
# =============================================================================
# SECURITY: Generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace_with_64_char_random_hex_string_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# NEXTAUTH (Frontend)
# =============================================================================
# SECURITY: Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_random_base64_string_openssl_rand_base64_32
# URL of your Next.js app (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# =============================================================================
# BACKEND API
# =============================================================================
# Internal URL used by Next.js server components to reach the FastAPI backend
BACKEND_URL=http://localhost:8000
# Public URL used by the browser to reach the FastAPI backend
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# CORS
# =============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# =============================================================================
# APPLICATION
# =============================================================================
ENVIRONMENT=development
# Set to "production" for production deployments
# LOG_LEVEL=info
